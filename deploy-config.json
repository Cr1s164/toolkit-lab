{
  "project": {
    "name": "toolkit-lab",
    "description": "完全免费的开发者工具集合网站",
    "version": "1.0.0"
  },
  "deployment": {
    "domestic": {
      "platform": "gitee-pages",
      "repository": "https://gitee.com/{username}/toolkit-lab",
      "url": "https://{username}.gitee.io/toolkit-lab",
      "branch": "main",
      "enabled": true,
      "config_file": ".gitee-pages.json"
    },
    "international": {
      "platform": "vercel",
      "url": "https://toolkit-site.vercel.app",
      "project_id": "prj_K0NtkLE0DzHXc89OppwFnteSs5kN",
      "enabled": true
    }
  },
  "sync": {
    "auto_sync": true,
    "sync_on_push": true,
    "backup_enabled": true
  },
  "monitoring": {
    "test_urls": [
      "https://toolkit-site.vercel.app",
      "https://{username}.gitee.io/toolkit-lab"
    ],
    "test_frequency": "daily"
  }
}